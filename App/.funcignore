# .funcignore — files excluded from the deployed Function App package.
# Syntax matches .gitignore.
#
# IMPORTANT: patterns without a leading "/" match recursively across the entire
# tree, including inside node_modules. That's almost never what we want for
# directory names like "src", "tests", "test", "coverage", because npm
# packages frequently ship folders by those names that are loaded at runtime.
# Anchor app-level paths with a leading "/" so they only apply to App/itself.

# ── App-level source (compiled to App/dist; not deployed) ──
/src/

# ── App-level tests ──
/tests/

# ── App-level build/config tooling ──
/build-widget.mjs
/tsconfig.json
/tsconfig.widget.json
/vitest.config.ts
/vitest.config.js
/.eslintrc*
/.eslintcache

# ── App-level local-dev/sample files ──
/local.settings.json
/local.settings.json.example
/README.md

# ── Source maps (anywhere — debug artifacts, never needed at runtime) ──
*.js.map

# ── TypeScript incremental-compile cache (anywhere — never needed at runtime) ──
*.tsbuildinfo

# ── VCS / editor / OS metadata (anywhere — safe to exclude) ──
.git*
.vscode/
.idea/
.DS_Store
Thumbs.db
