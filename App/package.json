{
  "name": "booking-widget-app",
  "version": "0.1.0",
  "description": "Azure Functions app that serves an embeddable Microsoft Bookings widget and the Microsoft Graph backend it talks to.",
  "private": true,
  "type": "module",
  "main": "dist/src/functions/*.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build:widget && npm run build:functions",
    "build:functions": "tsc",
    "build:widget": "node ./build-widget.mjs",
    "watch:functions": "tsc -w",
    "start": "func start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && npm run typecheck:widget",
    "typecheck:widget": "tsc --noEmit -p tsconfig.widget.json",
    "clean": "rimraf dist static"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.0",
    "@azure/functions": "^4.6.0",
    "@azure/identity": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
